{
  "name": "scrummer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "concurrently -n web,convex -c blue,magenta \"vite dev --port 5173\" \"bunx convex dev\"",
    "dev:web": "vite dev --port 5173",
    "dev:convex": "bunx convex dev",
    "build": "vite build",
    "build:vercel": "bunx convex deploy --cmd \"bun run build\" --cmd-url-env-var-name VITE_CONVEX_URL",
    "start": "vite preview --port 5173",
    "check": "vite build && tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^0.27.14",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@tanstack/react-router": "^1.160.2",
    "@tanstack/react-router-devtools": "^1.160.2",
    "@tanstack/react-start": "^1.160.2",
    "@tailwindcss/postcss": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "convex": "^1.32.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "y-codemirror.next": "^0.3.5",
    "yjs": "^13.6.29"
  }
}
