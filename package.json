{
  "name": "scrummer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 5173",
    "dev:server": "bun --watch server.ts",
    "dev:convex": "convex dev",
    "dev:all": "concurrently \"npm run dev:convex\" \"npm run dev\"",
    "build": "next build",
    "build:vercel": "bunx convex deploy --cmd \"bun run build\" --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL",
    "start": "next start --hostname 0.0.0.0 --port 5173",
    "check": "next build && tsc -p tsconfig.server.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.0.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "codemirror": "^6.0.2",
    "convex": "^1.32.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "y-codemirror.next": "^0.3.5",
    "yjs": "^13.6.29"
  }
}
